#!/usr/bin/env bash
# .githooks/pre-commit
# Exécuté avant chaque commit. Délègue à pre-commit framework si disponible,
# sinon effectue des vérifications minimales en fallback.
set -euo pipefail

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'

# ── 1. Vérification de l'environnement ─────────────────────────────────────
if ! command -v python &>/dev/null; then
  echo -e "${RED}✗ Python introuvable. Vérifiez votre virtualenv.${NC}" >&2
  exit 1
fi

# ── 2. Délégation au framework pre-commit ─────────────────────────────────
if command -v pre-commit &>/dev/null; then
  exec pre-commit run --hook-stage pre-commit
fi

# ── 3. Fallback : vérifications minimales sans pre-commit installé ──────────
echo -e "${YELLOW}⚠ pre-commit non installé — vérifications minimales activées.${NC}"
echo -e "${YELLOW}  Lancez : pip install pre-commit && pre-commit install${NC}"

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# Espaces en fin de ligne
if grep -rn ' $' $STAGED 2>/dev/null | grep -q .; then
  echo -e "${RED}✗ Espaces en fin de ligne détectés.${NC}" >&2
  exit 1
fi

# Ruff si disponible
if command -v ruff &>/dev/null; then
  ruff check $STAGED && ruff format --check $STAGED
fi

echo -e "${GREEN}✓ Vérifications pre-commit OK${NC}"
